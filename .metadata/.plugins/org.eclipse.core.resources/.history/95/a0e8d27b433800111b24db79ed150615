package com.example.hrpayroll.service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;

import com.example.hrpayroll.entity.Payment;
import com.example.hrpayroll.entity.Worker;
import com.example.hrpayroll.feignclient.WorkerFeignClient;

@Service
public class PayrollService {
	
	@Value("${hr-worker.host}")
	private String workerHost;
	
	private WorkerFeignClient workerFeignClient;
	
	@Autowired
	private RestTemplate restTemplate;
		
	public Payment getPayment(Long workderId, Integer days) {

		
		//Map<String,String> uriVariableMap = new HashMap<>();
		//uriVariableMap.put("id", ""+workderId);
		//Worker worker = restTemplate.getForObject(workerHost + "/workers/{id}",Worker.class, uriVariableMap);
		
		Worker worker = workerFeignClient.findById(workderId).getBody();
		
		return new Payment(worker.getName(), worker.getDalyIncome() , days);
	}
}
