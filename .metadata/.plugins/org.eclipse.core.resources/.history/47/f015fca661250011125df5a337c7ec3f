package com.gxhenrique.agendador_horarios.infrastructure.entity;

import java.time.LocalDateTime;

import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import jakarta.persistence.Table;



@Entity
@Table(name = "agendamento")
public class Agendamento {
	
	@Id
	@GeneratedValue(strategy = GenerationType.IDENTITY)
	private Long id;
	private String servico;
	private String profissional;
	private LocalDateTime dataHoraAgendamento;
	private String cliente;
	private LocalDateTime dateInsercao = LocalDateTime.now();
	
	public Agendamento() {
		
	}

	public Agendamento(Long id, String servico, String profissional, LocalDateTime dataHoraAgendamento,
			String cliente, LocalDateTime dateInsercao) {
		super();
		this.id = id;
		this.servico = servico;
		this.profissional = profissional;
		this.dataHoraAgendamento = dataHoraAgendamento;
		this.cliente = cliente;
		this.dateInsercao = dateInsercao;
	}

	public Long getId() {
		return id;
	}

	public void setId(Long id) {
		this.id = id;
	}

	public String getServico() {
		return servico;
	}

	public void setServico(String servico) {
		this.servico = servico;
	}

	public String getProfissional() {
		return profissional;
	}

	public void setProfissional(String profissional) {
		this.profissional = profissional;
	}

	public LocalDateTime getDataHoraAgendamento() {
		return dataHoraAgendamento;
	}

	public void setDataHoraAgendamento(LocalDateTime dataHoraAgendamento) {
		this.dataHoraAgendamento = dataHoraAgendamento;
	}

	public String getTelefoneCliente() {
		return cliente;
	}

	public void setTelefoneCliente(String cliente) {
		this.cliente = cliente;
	}

	public LocalDateTime getDateInsercao() {
		return dateInsercao;
	}

	public void setDateInsercao(LocalDateTime dateInsercao) {
		this.dateInsercao = dateInsercao;
	}
	
	
}
